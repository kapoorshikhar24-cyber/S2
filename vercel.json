{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/auth",
      "dest": "/api/auth.js"
    },
    {
      "src": "/api/users",
      "dest": "/api/users.js"
    },
    {
      "src": "/api/projects",
      "dest": "/api/projects.js"
    },
    {
      "src": "/api/entries",
      "dest": "/api/entries.js"
    },
    {
      "src": "/api/notifications",
      "dest": "/api/notifications.js"
    },
    {
      "src": "/api/sf-(.*)",
      "dest": "/api/sf.js"
    },
    {
      "src": "/js/(.*)",
      "dest": "/public/js/$1"
    },
    {
      "src": "/css/(.*)",
      "dest": "/public/css/$1"
    },
    {
      "src": "/styles/(.*)",
      "dest": "/public/styles/$1"
    },
    {
      "src": "/images/(.*)",
      "dest": "/public/images/$1"
    },
    {
      "src": "/scripts/(.*)",
      "dest": "/public/scripts/$1"
    },
    {
      "src": "/src/(.*)",
      "dest": "/src/$1"
    },
    {
      "src": "/app\\.js",
      "dest": "/app.js"
    },
    {
      "src": "/style\\.css",
      "dest": "/style.css"
    },
    {
      "src": "/mom\\.html",
      "dest": "/public/mom.html"
    },
    {
      "src": "/salesforce\\.html",
      "dest": "/public/salesforce.html"
    },
    {
      "src": "/salesforce_playwright\\.py",
      "dest": "/public/salesforce_playwright.py"
    },
    {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}